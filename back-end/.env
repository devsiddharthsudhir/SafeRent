# Render will provide PORT automatically
PORT=4000

# Comma-separated allowed origins (recommended in production)
# Example:
# CORS_ORIGIN=https://your-site.netlify.app,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:5173

NODE_ENV=production

# Heavy endpoint limiter (per IP)
RATE_LIMIT_HEAVY_PER_MIN=30

# Admin endpoints (optional)
# If set, calls to /api/admin/* must include:
#   Authorization: Bearer <ADMIN_TOKEN>
# or:
#   x-admin-token: <ADMIN_TOKEN>
ADMIN_TOKEN=

# Data retention (privacy)
# In production, keep these small by default.
RETENTION_ENABLED=true
RETENTION_DAYS=30
CACHE_RETENTION_DAYS=7
UPLOADS_RETENTION_DAYS=7
RETENTION_RUN_ON_START=true
RETENTION_SWEEP_EVERY_HOURS=24

# --- Cross-site verification (optional, for higher correctness) ---
# If enabled, SafeRent will try to find the same listing on other sites
# and compare pricing. This runs in the background after the initial score.

# Enable / disable enrichment
WEB_VERIFY_ENABLED=true

# Providers
# 1) Paid (more reliable): Serper (Google results) + Brave Search
# 2) Free fallback: DuckDuckGo HTML results (no key required)
#
# If you do NOT set paid keys, the backend will automatically fall back to DuckDuckGo.
# For beta launch: start with DuckDuckGo, then add Serper/Brave when you want higher recall.

# Paid provider keys (set one or both)
SERPER_API_KEY=a3073994cc03bfb041960a85e1bea9fe7e30b6b7
BRAVE_SEARCH_API_KEY=

# Free provider toggle (enabled by default)
WEB_VERIFY_DDG_ENABLED=true

# Lease LLM enhancement (optional). If enabled, text is redacted before LLM.
LEASE_LLM_ENABLED=false
OPENAI_API_KEY=

# Thresholds (riskProbability is 0..1)
# - below LOW: skip auto verification
# - between LOW and HIGH: Serper only (fallback to DDG/Brave if Serper not set)
# - above HIGH: Serper + Brave in parallel (fallback to DDG if one key missing)
CROSSPOST_THRESHOLD_LOW=0.45
CROSSPOST_THRESHOLD_HIGH=0.60

# Timeouts (ms)
WEB_VERIFY_SEARCH_TIMEOUT_MS=2000
WEB_VERIFY_PAGE_TIMEOUT_MS=2500

# Daily caps (safety for free/low-cost tiers)
SERPER_DAILY_LIMIT=400
BRAVE_DAILY_LIMIT=400
DDG_DAILY_LIMIT=300

# Optional: allow detail scraping for crosspost matches.
# Safe default is "same host only".
# Example allowlist:
# CROSSPOST_FETCH_ALLOWLIST=craigslist.org,kijiji.ca,rentfaster.ca,rentals.ca
CROSSPOST_FETCH_ALLOWLIST=

# Optional: budgets/caching
CROSSPOST_DETAIL_FETCH_MAX=4
CROSSPOST_DETAIL_FETCH_TTL_MS=21600000
CROSSPOST_IMAGE_HASH_TTL_MS=86400000
