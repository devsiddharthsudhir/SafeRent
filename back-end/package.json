{
  "name": "saferent-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run build",
    "train": "tsx src/train.ts",
    "eval": "tsx src/eval.ts",
    "train:fast": "tsx src/train.ts --no-calibrate --report",
    "train:all": "tsx src/train.ts --calibrate --report",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write .",
    "test": "node --test"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "jimp": "^0.22.12",
    "multer": "^2.0.2",
    "nanoid": "^5.0.7",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "eslint": "^9.22.0",
    "@eslint/js": "^9.22.0",
    "typescript-eslint": "^8.26.0",
    "prettier": "^3.5.3"
  }
}
